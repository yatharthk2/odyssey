# Copy to .env and fill in. The .env file lives on the production server only
# — never commit it. The repo's root .gitignore already covers **/.env.

# --- Required ---------------------------------------------------------------
GROQ_API_KEY=
Google_Gemini_API_KEY=

# --- Optional (defaults shown) ---------------------------------------------

# CORS — restrict to your Vercel frontend in prod.
ALLOWED_ORIGINS=https://yatharthk.com,https://www.yatharthk.com

# LLM provider on first boot. The frontend can still flip it per-request.
# DEFAULT_MODEL_PROVIDER=groq
