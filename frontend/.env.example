# Frontend environment variables.
# Anything that needs to be visible in the browser must be prefixed NEXT_PUBLIC_.
# In Vercel, set these under Project -> Settings -> Environment Variables.

# Full WebSocket URL of the Inpersona backend.
# Leave unset in local dev — the chat will fall back to
# `${ws|wss}://${window.location.hostname}:8000/chat`.
# In production, point this at your Hetzner backend:
NEXT_PUBLIC_INPERSONA_WS_URL=wss://api.yatharthk.com/chat
