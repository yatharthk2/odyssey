# Required — server refuses to start without these.
GROQ_API_KEY=
Google_Gemini_API_KEY=

# Optional — only required if you use the openai provider (either via
# DEFAULT_MODEL_PROVIDER=openai at startup, or per-request from a client).
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional — defaults shown.
# REDIS_URL=redis://localhost:6379
# DEFAULT_MODEL_PROVIDER=groq         # groq | gemini | openai
# ALLOWED_ORIGINS=*
# HOST=0.0.0.0
# PORT=8000
# WEBSOCKET_PATH=/chat
# PDF_DIRECTORY=./documents
# SSL_CERT_PATH=/etc/ssl/yatharthk.com.crt
# SSL_KEY_PATH=/etc/ssl/yatharthk.com.key
# SSL_CA_PATH=/etc/ssl/ca_bundle.crt
